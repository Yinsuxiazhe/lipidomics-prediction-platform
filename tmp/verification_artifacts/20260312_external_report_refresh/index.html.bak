<button class="scroll-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" title="回到顶部">↑</button>
<script>
    const scrollBtn = document.querySelector('.scroll-top');
    window.addEventListener('scroll', () => {
      scrollBtn.style.opacity = window.scrollY > 300 ? '1' : '0';
      scrollBtn.style.pointerEvents = window.scrollY > 300 ? 'auto' : 'none';
    });
    scrollBtn.style.opacity = '0';
    scrollBtn.style.pointerEvents = 'none';
    scrollBtn.style.transition = 'opacity 0.3s';

    const tocLinks = document.querySelectorAll('.sidebar-toc-link');
    const sections = Array.from(document.querySelectorAll('.article-main h2[id], .article-main h3[id]'));

    function setActiveLink() {
      let currentId = '';
      const offset = window.scrollY + 120;
      for (const section of sections) {
        if (section.offsetTop <= offset) {
          currentId = section.id;
        }
      }
      tocLinks.forEach(link => {
        link.classList.toggle('active', link.dataset.target === currentId);
      });
    }

    window.addEventListener('scroll', setActiveLink);
    window.addEventListener('load', setActiveLink);
  

    async function copyExampleText(text, button) {
      const original = button.dataset.originalLabel || button.textContent;
      if (!button.dataset.originalLabel) {
        button.dataset.originalLabel = original;
      }

      function mark(stateClass, label) {
        button.classList.remove('copied', 'failed');
        if (stateClass) {
          button.classList.add(stateClass);
        }
        button.textContent = label;
        window.setTimeout(() => {
          button.classList.remove('copied', 'failed');
          button.textContent = original;
        }, 1800);
      }

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
          mark('copied', '已复制');
          return;
        }
      } catch (error) {
        console.warn('navigator.clipboard failed, falling back', error);
      }

      try {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', 'readonly');
        textarea.style.position = 'fixed';
        textarea.style.top = '-9999px';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();
        const successful = document.execCommand('copy');
        document.body.removeChild(textarea);
        mark(successful ? 'copied' : 'failed', successful ? '已复制' : '复制失败');
      } catch (error) {
        console.error('copy fallback failed', error);
        mark('failed', '复制失败');
      }
    }

    document.querySelectorAll('.copy-example-btn').forEach((button) => {
      button.addEventListener('click', () => {
        copyExampleText(button.dataset.copyText || '', button);
      });
    });
</script>
</body>
